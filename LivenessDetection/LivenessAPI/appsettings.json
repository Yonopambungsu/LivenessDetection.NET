{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Liveness": {
    "ScrfdModelPath": "detection/scrfd_10g_bnkps.onnx",
    "LandmarkModelPath": "landmark/2d106det.onnx",
    "RecognitionModelPath": "recognition/glintr100.onnx",
    "AntiSpoofModelPath": "spoof/MiniFASNetV2.onnx",
    "DetectionInputSize": 320,
    "DetectionScoreThreshold": 0.5,
    "DetectionNmsThreshold": 0.4,
    "AntiSpoofEnabled": true,
    "AntiSpoofCropScale": 2.7,
    "AntiSpoofRealClassIndex": 1,
    "AntiSpoofThreshold": 0.6,
    "RecognitionThreshold": 0.35,
    "BlinkClosedRatio": 0.75,
    "BlinkRecoverRatio": 0.85,
    "SmileRatioThreshold": 0.38,
    "YawOffsetThreshold": 0.18,
    "SessionTtlSeconds": 120,
    "ChallengeCount": 2,
    "RequiredConsecutiveFrames": 2
  }
}
