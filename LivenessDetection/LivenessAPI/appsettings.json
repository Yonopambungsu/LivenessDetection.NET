{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Liveness": {
    "YunetModelPath": "detection/face_detection_yunet.onnx",
    "LandmarkModelPath": "landmark/pipnet_r18_300w_celeba_68.onnx",
    "RecognitionModelPath": "recognition/glintr100-aura-face.onnx",
    "AntiSpoofModelPath": "spoof/MiniFASNetV2.onnx",
    "DetectionInputSize": 320,
    "DetectionScoreThreshold": 0.5,
    "DetectionNmsThreshold": 0.4,
    "AntiSpoofEnabled": true,
    "AntiSpoofCropScale": 2.7,
    "AntiSpoofRealClassIndex": 1,
    "AntiSpoofThreshold": 0.6,
    "RecognitionThreshold": 0.35,
    "UseFixedChallengeOrder": false,
    "FixedChallengeOrder": [ "Blink", "LookLeft", "LookRight", "Smile" ],
    "MaxRetriesPerChallenge": 1,
    "CalibrationSeconds": 1.0,
    "TransitionMinSeconds": 0.4,
    "TransitionMaxSeconds": 3.0,
    "MinFaceAreaRatio": 0.06,
    "MaxFaceAreaRatio": 0.45,
    "FaceCenterToleranceRatio": 0.22,
    "IncludeDebugMetrics": true,
    "InvertYawSign": true,
    "YawOffsetThreshold": 0.10,
    "YawNeutralThreshold": 0.10,
    "YawRequiredConsecutiveFrames": 2,
    "BlinkClosedRatio": 0.78,
    "BlinkRecoverRatio": 0.88,
    "BlinkRequiredConsecutiveFrames": 2,
    "SmileDeltaThreshold": 0.06,
    "SmileCalibrationFrames": 3,
    "SmileRequiredConsecutiveFrames": 2,
    "ChallengeCount": 3,
    "SessionTtlSeconds": 300,
    "RequiredConsecutiveFrames": 3,
    "MaxSecondsPerChallenge": 15
  }
}
